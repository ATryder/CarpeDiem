[application]

config/name="Carpe Diem"
run/main_scene="res://scenes/UI/menus/MainMenu.tscn"
boot_splash/image="res://black32.png"
boot_splash/bg_color=Color( 0, 0, 0, 1 )
config/icon="res://icon.png"
config/windows_native_icon="res://icons/icon.ico"
config/name_en="Carpe Diem"

[autoload]

Math="*res://scripts/util/Math.gd"
CD="*res://scripts/Globals.gd"
Audio="*res://scripts/Audio.gd"
Music="*res://scripts/Music.gd"
Opts="*res://scripts/Options.gd"
Dossier="*res://scripts/Dossier.gd"
SceneLoader="*res://scripts/SceneLoader.gd"

[display]

window/stretch/mode="2d"
window/stretch/aspect="expand"

[gui]

theme/custom="res://default_theme.theme"
theme/custom_font="res://fonts/DefaultFont.tres"

